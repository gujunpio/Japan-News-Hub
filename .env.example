# Japan News Hub — Environment Variables
# Copy this file to .env.local and fill in your values

# Optional: Custom Chromium path (used by Yahoo News scraper)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/path/to/chromium

# Optional: Remote Chromium URL for Vercel deployment
# CHROMIUM_REMOTE_URL=https://your-chromium-url.com/chromium.tar.gz

# Docker detection (set automatically in Dockerfile)
# DOCKER=1
